rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user has Manager role in Firestore
    function isManager() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager';
    }

    // Helper: Check if user has Active status in Firestore
    function isActive() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'Active';
    }

    // Users Collection rules
    match /users/{userId} {
      // Any authenticated active user can read profiles (needed for guest lookup and checkout assignments)
      allow read: if isActive();
      
      // Users can write/update their own contact phone if active (e.g. self-profile editing)
      allow update: if isActive() && request.auth.uid == userId;
      
      // Creating, deleting, or changing roles/statuses requires Manager role
      allow create, delete: if isManager();
      allow update: if isManager();
    }

    // Operational Collections rules (Bookings, Rooms, Guests, Invoices, Payments, etc.)
    match /rooms/{roomId} {
      allow read, write: if isActive();
    }

    match /room_types/{typeId} {
      allow read: if isActive();
      allow write: if isManager();
    }

    match /guests/{guestId} {
      allow read, write: if isActive();
    }

    match /bookings/{bookingId} {
      allow read, write: if isActive();
      // Restrict booking deletion to Managers
      allow delete: if isManager();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isActive();
      // Restrict direct manual invoice editing to Managers
      allow update: if isManager();
    }

    match /payments/{paymentId} {
      allow read, write: if isActive();
      // Voiding payments is restricted to Managers
      allow update, delete: if isManager();
    }

    // Administrative & Security Collections
    match /audit_logs/{logId} {
      // Only Managers can read or write audit logs
      allow read, write: if isManager();
    }

    match /website_settings/{settingId} {
      // Receptionist can read setting options, only Manager can update
      allow read: if isActive();
      allow write: if isManager();
    }

    match /notifications/{notifId} {
      allow read, write: if isActive();
    }

    match /booking_requests/{reqId} {
      allow read, write: if isActive();
    }

    match /contact_inquiries/{inqId} {
      allow read, write: if isActive();
    }
  }
}
